{
  "name": "mern-todo-app-tests",
  "version": "1.0.0",
  "description": "QA Assignment tests",
  "scripts": {
    "test": "jest --coverage",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run"
  },
  "devDependencies": {
    "cypress": "^13.0.0",
    "express": "^4.18.2",
    "jest": "^29.0.0",
    "mongoose": "^7.0.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "rootDir": "..",
    "testMatch": [
      "<rootDir>/qa-assignment/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "<rootDir>/mern-todo-app/TODO/todo_backend/**/*.js",
      "<rootDir>/qa-assignment/tests/utils.js"
    ]
  }
}
